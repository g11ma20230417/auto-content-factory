# Seedance Configuration
SEEDANCE_URL=https://www.seedance.tv
SEEDANCE_EMAIL=your_email@gmail.com
SEEDANCE_PASSWORD=your_password

# YouTube Configuration
YOUTUBE_EMAIL=your_email@gmail.com
YOUTUBE_PASSWORD=your_password
YOUTUBE_API_KEY=your_api_key

# Browser Configuration
HEADLESS=false
SLOW_MO=100

# Paths
SCREENSHOT_DIR=./logs/screenshots
VIDEO_OUTPUT_DIR=./output/videos
LOG_FILE=./logs/automation.log

# Timing
MIN_DELAY=0.5
MAX_DELAY=2.0

# YouTube Upload Settings
DEFAULT_TITLE=Amazing AI Generated Video
DEFAULT_DESCRIPTION=Created with Seedance AI
DEFAULT_TAGS=AI,artificial intelligence,AI art,AI video
